# Application
APP_NAME=jobfit-ai
APP_ENV=development
APP_PORT=8000

# Database (Docker로 PostgreSQL 띄운 뒤 사용)
DATABASE_URL=postgresql+psycopg://jobfit_user:CHANGE_ME@localhost:5432/jobfit_db

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14